# ── Groq AI ───────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# Example (Neon / PostgreSQL):
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@localhost/edusummarizer

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# Optional: override token lifetime in minutes (default = 10080 = 7 days)
# ACCESS_TOKEN_EXPIRE_MINUTES=10080
